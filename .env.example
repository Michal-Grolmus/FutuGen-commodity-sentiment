# Anthropic API (leave empty for demo mode)
ANTHROPIC_API_KEY=

# Whisper settings
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=en

# Ingestion (leave empty for onboarding + demo mode)
CHUNK_DURATION_S=10
STREAM_URL=
INPUT_FILE=

# Pipeline
MAX_QUEUE_SIZE=50
PIPELINE_TIMEOUT_S=1800

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# RAG: enrich scoring with live commodity prices
ENABLE_PRICE_TRACKING=true

# Bonus: Slack notifications
SLACK_WEBHOOK_URL=
NOTIFICATION_CONFIDENCE_THRESHOLD=0.8
